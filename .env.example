# Copy to .env.local and fill in. .env.local is gitignored; never commit real
# values. Production secrets live only in the Vercel and Supabase dashboards.

# --- Supabase -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=              # e.g. http://127.0.0.1:54321 for local stack
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon key printed by `supabase start`; safe to expose to the browser
SUPABASE_SERVICE_ROLE_KEY=             # service_role key; server-only, never imported from client code
SUPER_ADMIN_EMAIL=                     # email promoted to admin by supabase/seed.sql via ensure_super_admin()
